rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user (including guests via anonymous auth) can only
    // read or write their own data, scoped under users/{uid}.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{collection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
