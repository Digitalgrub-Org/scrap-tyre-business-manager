# App Store Connect API key configuration (template — contains NO secrets).
#
# Recommended: put these two lines in ~/.zprofile so EVERY project reuses them:
#
#   export ASC_KEY_ID="XXXXXXXXXX"
#   export ASC_ISSUER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#
# Alternatively, copy this file to fastlane/.env (per project) and fill it in.
#
# The secret .p8 key file is NEVER committed. It lives here and is shared by
# all projects:
#
#   ~/.appstoreconnect/private_keys/AuthKey_${ASC_KEY_ID}.p8

ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional. Defaults to ~/.appstoreconnect/private_keys/AuthKey_${ASC_KEY_ID}.p8
# ASC_KEY_PATH=/Users/theone/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
