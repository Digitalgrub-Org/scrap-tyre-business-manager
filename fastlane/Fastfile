# Fastfile — App Store Connect automation for Scrap Tyre Business Manager
#
# Authentication uses an App Store Connect API key (recommended).
# The secret .p8 key lives OUTSIDE this repo, in a shared folder so every
# project on this Mac reuses the same key:
#
#   ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8
#
# Set these two values in your shell profile (~/.zprofile) once, and all
# projects pick them up:
#
#   export ASC_KEY_ID="XXXXXXXXXX"
#   export ASC_ISSUER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#
# Usage (run from the project root):
#   fastlane create_app          # registers the bundle id and creates the app record
#   fastlane upload_metadata     # pushes the listing text fields
#   fastlane upload_screenshots  # uploads images from fastlane/screenshots

default_platform(:ios)

APP_IDENTIFIER = "com.digitalgrub.scrapTyreBusinessManager"
APP_NAME       = "Scrap Tyre Business Manager"
SKU            = "scrapTyreBusinessManager"
APP_VERSION    = "1.0"
TEAM_ID        = ENV.fetch("ASC_TEAM_ID", "HYLU87Y7JM")

def asc_api_key
  key_id = ENV.fetch("ASC_KEY_ID") { UI.user_error!("Set ASC_KEY_ID in your shell profile (~/.zprofile)") }
  issuer = ENV.fetch("ASC_ISSUER_ID") { UI.user_error!("Set ASC_ISSUER_ID in your shell profile (~/.zprofile)") }
  key_path = ENV["ASC_KEY_PATH"] ||
             File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8")
  UI.user_error!("API key file not found at #{key_path}") unless File.exist?(key_path)
  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer,
    key_filepath: key_path,
    duration: 1200,
    in_house: false
  )
end

platform :ios do
  desc "Register the bundle id and create the app record on App Store Connect"
  lane :create_app do
    # produce has no api_key option; calling this action sets the App Store
    # Connect API token globally so produce uses it automatically.
    asc_api_key
    produce(
      app_identifier: APP_IDENTIFIER,
      app_name: APP_NAME,
      language: "English (U.S.)",
      sku: SKU
    )
    UI.success("App record created (or already existed) for #{APP_IDENTIFIER}")
  end

  desc "Upload the listing text fields only (no binary, no screenshots)"
  lane :upload_metadata do
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      app_version: APP_VERSION,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      automatic_release: false
    )
  end

  desc "Upload screenshots from fastlane/screenshots (no binary, no text)"
  lane :upload_screenshots do
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      app_version: APP_VERSION,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false
    )
  end

  desc "Build a signed App Store ipa and upload the binary (signing via API key)"
  lane :release do
    api = asc_api_key
    key_id = ENV.fetch("ASC_KEY_ID")
    issuer = ENV.fetch("ASC_ISSUER_ID")
    key_path = ENV["ASC_KEY_PATH"] ||
               File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8")
    # Automatic signing. build_app injects the API key into the archive step;
    # the export step needs it passed explicitly via export_xcargs. xcodebuild
    # then creates the distribution certificate and App Store profile with no
    # Apple ID login. We do NOT set a manual profile globally, because that
    # breaks Swift Package targets that do not support provisioning profiles.
    export_auth = "-allowProvisioningUpdates " \
                  "-authenticationKeyPath #{key_path} " \
                  "-authenticationKeyID #{key_id} " \
                  "-authenticationKeyIssuerID #{issuer}"
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ios/ipa",
      output_name: "Runner.ipa",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{TEAM_ID}",
      export_xcargs: export_auth,
      export_options: { teamID: TEAM_ID, signingStyle: "automatic" }
    )
    upload_to_app_store(
      api_key: api,
      app_identifier: APP_IDENTIFIER,
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      run_precheck_before_submit: false,
      submit_for_review: false
    )
  end
end
